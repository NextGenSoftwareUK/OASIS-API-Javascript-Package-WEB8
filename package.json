{
  "name": "@oasisomniverse/web8-api",
  "version": "1.0.2",
  "publishConfig": { "access": "public" },
  "description": "Isomorphic (Node + browser) JavaScript/TypeScript-friendly client for the WEB8 OASIS Galactic Mesh API - fractal holonic mesh node registration, link/route computation, self-healing message relay, and protocol-bridge translation between external wire formats and the unified MeshMessage envelope, built on the OASIS WEB8 WebAPI.",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "src",
    "docs"
  ],
  "scripts": {
    "generate": "node scripts/generate-modules.js",
    "docs": "node scripts/generate-docs.js",
    "types": "node scripts/generate-types.js",
    "test": "node --test test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NextGenSoftwareUK/OASIS-API-Javascript-Package-WEB8.git"
  },
  "author": "NextGen Software Ltd",
  "license": "MIT",
  "keywords": [
    "WEB8 Galactic Mesh API",
    "WEB8 WebAPI",
    "OASIS Galactic Mesh",
    "Holonic Mesh",
    "Self-Healing Routing",
    "Protocol Bridge",
    "Mesh Networking",
    "OASIS API",
    "WEB 4",
    "WEB 5",
    "WEB 6",
    "WEB 7",
    "WEB 8",
    "Blockchain",
    "Interoperable",
    "Metaverse",
    "Aggregation",
    "HOT-Swappable-Architecture",
    "Decentralised",
    "Distributed",
    "Abstraction-Layer",
    "Multi-Network",
    "SSO",
    "Agent-Centric",
    "GOD-Protocol/API",
    "More Coming..."
  ]
}
